# ============================================================
# .assist.env — OAuth Credentials untuk SIS/Assist Middleware
# ============================================================
# Salin file ini menjadi .assist.env dan isi dengan nilai asli.
# JANGAN commit file .assist.env ke git (sudah di .gitignore)!
#
# =======================================================================
# PENTING: Perbedaan OAUTH_SERTIFIKAT vs OAUTH_CLIENT_ID
# =======================================================================
#
#   OAUTH_SERTIFIKAT  ← KodeSertifikat di tabel `sertifikat` DB auth2_access
#                       (db.auth.access.sis1.net)
#                       Dikirim sebagai: Authorization: Bearer {OAUTH_SERTIFIKAT}
#                       Contoh: 82e253651d3fe3721fcefae8e8a3bfab
#
#   OAUTH_CLIENT_ID   ← auth_client_id BPR = kode OAuth2 SSO di myassist.id
#                       TIDAK digunakan sebagai KodeSertifikat
#                       Contoh: 000143
#
# Cara mendapatkan OAUTH_SERTIFIKAT:
#   1. Tanya admin SIS / jalankan query di DB auth2_access:
#      SELECT KodeSertifikat, KodeAplikasi, Platform, Username
#      FROM sertifikat WHERE StatusPublish=1 LIMIT 10
#   2. Atau cek tabel accesstoken:
#      SELECT KodeSertifikat, KodeAplikasi, DeviceID, Username, Platform, VersiAplikasi
#      FROM accesstoken ORDER BY DateTimeCreated DESC LIMIT 5
#
# Cara mendapatkan OAUTH_USERNAME / OAUTH_PASSWORD:
#   → Kolom Username di tabel accesstoken (contoh: 'ABSEN')
#   → Atau tanya admin SIS
#
# Cara mendapatkan OAUTH_KODE_APLIKASI:
#   → Kolom KodeAplikasi di tabel accesstoken (contoh: 'MRA000175')
#
# DE061_SIM_SERIAL (DeviceID):
#   → IP server (dari tabel accesstoken kolom DeviceID, contoh: '10.0.5.52')
#   → Jika kosong, script otomatis pakai $_SERVER['SERVER_ADDR']
#
# Letakkan file .assist.env di salah satu lokasi berikut:
#   1. Direktori yang sama dengan script PHP ini
#   2. Satu direktori di atasnya
#   3. Dua direktori di atasnya
# ============================================================

# KodeSertifikat di tabel sertifikat DB auth2_access — WAJIB DIISI
OAUTH_SERTIFIKAT=isi_kode_sertifikat_dari_admin_sis

# auth_client_id BPR (untuk OAuth2 SSO myassist.id — opsional, bukan untuk token assist-switching)
OAUTH_CLIENT_ID=isi_client_id_bpr_opsional
OAUTH_CLIENT_SECRET=isi_client_secret_bpr_opsional

# Username untuk H2H token request (dari kolom Username di tabel accesstoken)
OAUTH_USERNAME=ABSEN
OAUTH_PASSWORD=isi_password_h2h

# KodeAplikasi dari tabel accesstoken (contoh: MRA000175)
OAUTH_KODE_APLIKASI=MRA000175

# DeviceID = IP server dari tabel accesstoken (contoh: 10.0.5.52)
# Jika kosong, diambil otomatis dari $_SERVER['SERVER_ADDR']
DE061_SIM_SERIAL=10.0.5.52
