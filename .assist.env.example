# .assist.env — OAuth Credentials untuk SIS/Assist Middleware
# ============================================================
# PETUNJUK PENGGUNAAN:
#   1. Salin file ini menjadi .assist.env (tanpa .example)
#   2. Isi nilai masing-masing field dari administrator SIS/Assist
#   3. JANGAN commit file .assist.env ke repository (sudah ada di .gitignore)
#
# Tempatkan file ini di salah satu lokasi (akan dicari otomatis):
#   - Direktori yang sama dengan script PHP (./inquiry_*.php)
#   - Satu level di atas script
#   - Dua level di atas script
#   - Direktori root assist-switching_v3_pro
#
# Nilai KODE_AGEN, MFTFI, URL, dan CICD otomatis dibaca dari source code.
# Hanya credential OAuth yang perlu diisi di sini (karena disimpan di database).
# ============================================================

# OAuth Credentials (dari administrator SIS/Assist)
OAUTH_CLIENT_ID=isi_client_id_dari_admin
OAUTH_CLIENT_SECRET=isi_client_secret_dari_admin

# Username H2H (nilai UserH2H dari tabel agen di database)
OAUTH_USERNAME=isi_username_H2H
OAUTH_PASSWORD=isi_password_H2H

# SIMSerial / Device Identifier (opsional)
# Nilai dari kolom SIMSerial di tabel agen_aktifasi
# Format: kode_bank_4digit + serial_perangkat
# Contoh: 00268ABCDEF (KodeBank 00268 + serial)
DE061_SIM_SERIAL=
