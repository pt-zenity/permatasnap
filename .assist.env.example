# ============================================================
# .assist.env — OAuth Credentials untuk SIS/Assist Middleware
# ============================================================
# Salin file ini menjadi .assist.env dan isi dengan nilai asli.
# JANGAN commit file .assist.env ke git (sudah di .gitignore)!
#
# Cara mendapatkan nilai:
#   - OAUTH_CLIENT_ID / OAUTH_CLIENT_SECRET → dari administrator SIS/Assist
#   - OAUTH_USERNAME / OAUTH_PASSWORD       → dari kolom UserH2H tabel agen di database
#   - DE061_SIM_SERIAL                      → dari tabel agen_fitur (SIMSerial perangkat)
#
# Letakkan file .assist.env di salah satu lokasi berikut:
#   1. Direktori yang sama dengan script PHP ini
#   2. Satu direktori di atasnya
#   3. Dua direktori di atasnya
# ============================================================

OAUTH_CLIENT_ID=isi_client_id_dari_admin_sis
OAUTH_CLIENT_SECRET=isi_client_secret_dari_admin_sis
OAUTH_USERNAME=UserH2H_dari_tabel_agen_database
OAUTH_PASSWORD=password_H2H_agen
DE061_SIM_SERIAL=sim_serial_perangkat_agen_opsional
